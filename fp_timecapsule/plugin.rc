#if !defined(AFX_RESOURCE_DLL) || defined(AFX_TARG_ENU)
LANGUAGE LANG_ENGLISH, SUBLANG_ENGLISH_US
#pragma code_page(1252)

IDD_DIALOG_TIMECAPSULE DIALOGEX 0, 0, 236, 164
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Create time capsule"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    LTEXT           "Title:",IDC_STATIC,7,7,222,8
    EDITTEXT        IDC_EDIT_TITLE,7,18,222,14,ES_AUTOHSCROLL
    LTEXT           "Sorting:",IDC_STATIC,7,40,70,8
    COMBOBOX        IDC_COMBO_SORT_MODE,82,37,147,80,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Controls the order of both the pictures and the connected points in the graph.",IDC_STATIC,7,57,222,16
    CONTROL         "Show metadata on poster",IDC_CHECK_METADATA,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,7,77,132,10
    LTEXT           "Thumbnail width:",IDC_STATIC,7,98,70,8
    EDITTEXT        IDC_EDIT_THUMB_WIDTH,82,95,38,14,ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "Thumbnail height:",IDC_STATIC,129,98,70,8
    EDITTEXT        IDC_EDIT_THUMB_HEIGHT,198,95,31,14,ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "Location radius (km):",IDC_STATIC,7,120,76,8
    EDITTEXT        IDC_EDIT_LOCATION_RADIUS,82,117,38,14,ES_AUTOHSCROLL
    DEFPUSHBUTTON   "OK",IDOK,54,143,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,131,143,50,14
END

STRINGTABLE
BEGIN
    IDS_PLUGIN_SHORT_DESC   "Time Capsule"
    IDS_PLUGIN_LONG_DESC    "Time capsule function plugin"
    IDS_PLUGIN_INFO         "Builds a story poster from the selected pictures with a timeline, summary, and thumbnails."
    IDS_MIN_SELECTION       "Select at least two pictures for the time capsule."
    IDS_DEFAULT_TITLE       "My Time Capsule"
    IDS_SORT_MODE_EXIF      "EXIF time"
    IDS_SORT_MODE_SELECTION "Selection order"
    IDS_SORT_MODE_WEST_EAST "GPS west to east"
    IDS_SORT_MODE_NORTH_SOUTH "GPS north to south"
    IDS_SORTING_LABEL       "Sorting"
END

